{
  "expo": {
    "name": "Ecommerce",
    "slug": "Ecommerce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    //plugin agregado para solicitar permisos de acceso a las fotos del dispositivo
    "plugins": [
      [
      "expo-image-picker",{
        "photopermissions": "La aplicación necesita acceso a tus fotos para que puedas elegir una imagen"
      }
    ]
  ]
  }
}
